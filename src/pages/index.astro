---
const defaultLang = "en";

// src/pages/index.astro solo matchea la raíz exacta `/` por routing
// de archivos de Astro, así que basta con comprobar `=== '/'`. La
// capa `location = / { return 301 /en/; }` de `default.conf`
// (y el bloque `redirects` de `firebase.json`) ya neutralizan este
// HTML en producción/preview — este archivo es solo un fallback
// para `astro dev` y otros hosts sin redirect configurado.
if (Astro.url.pathname === "/") {
  return Astro.redirect(`/${defaultLang}/`);
}
