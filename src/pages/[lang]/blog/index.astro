---
import { getCollection } from "astro:content";
import BlogPreview from "../../../components/blog-preview.astro";
import Grid from "../../../components/Grid.astro";
import Hero from "../../../components/ui/Hero.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getTranslations } from "../../../data/i18n";
import { entriesForLang } from "../../../lib/content-helpers";

export async function getStaticPaths() {
  const locales = ["es", "en"];

  return locales.map((lang) => ({
    params: { lang },
  }));
}

const lang = (Astro.url.pathname.split("/")[1] as "es" | "en") || "en";
const t = getTranslations(lang);

// Full list scoped to current `lang`, newest-first. Same filter
// contract as the home page (see `lib/content-helpers.ts`).
const allBlogPost = entriesForLang(await getCollection("blog"), lang);
---

<BaseLayout title={t.blog.title} description={t.blog.description}>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero title={t.blog.title} tagline={t.blog.description} align="start" />
      <Grid variant="offset">
        {
          allBlogPost.map((blog) => (
            <li>
              <BlogPreview blog={blog} />
            </li>
          ))
        }
      </Grid>
    </main>
  </div>
</BaseLayout>
