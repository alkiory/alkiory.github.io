---
import { getTranslations, type Lang } from "../../data/i18n";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon, { type Props as IconProps } from "../../components/ui/icon.astro";

export async function getStaticPaths() {
  const locales = ["es", "en"];

  return locales.map((lang) => ({
    params: { lang },
  }));
}

const lang = (Astro.url.pathname.split("/")[1] as Lang) || "en";
const t = getTranslations(lang);

// Reutilizamos las mismas redes sociales declaradas en el Nav para que
// la página de contacto se mantenga sincronizada con un solo punto de
// cambio.
const socials: { label: string; href: string; icon: IconProps["icon"] }[] = [
  { label: "GitHub", href: "https://github.com/alkiory", icon: "github-logo" },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/iamsergiocampbell",
    icon: "linkedin-logo",
  },
  {
    label: "YouTube",
    href: "https://www.youtube.com/@iamsergiocampbell",
    icon: "youtube-logo",
  },
  {
    label: "CodePen",
    href: "https://codepen.io/sergiocampbell",
    icon: "codepen-logo",
  },
  {
    label: "Twitter",
    href: "https://twitter.com/alkiory",
    icon: "twitter-logo",
  },
];

const email = "sergiocampbelldev@gmail.com";
---

<BaseLayout title={t.contact.title} description={t.contact.description}>
  <main class="wrapper contact-page stack gap-20">
    <header class="contact-header stack gap-4">
      <h1 class="contact-title">{t.contact.title}</h1>
      <p class="contact-description">{t.contact.description}</p>
    </header>

    <section class="contact-card stack gap-6">
      <a class="contact-email" href={`mailto:${email}`}>
        <Icon icon="envelope" size="1.5em" />
        <span>{email}</span>
      </a>

      <div class="contact-divider" role="presentation"></div>

      <div class="contact-socials stack gap-3">
        <p class="contact-socials-label">{t.contact.findMeOn}</p>
        <ul class="contact-social-list">
          {
            socials.map(({ label, href, icon }) => (
              <li>
                <a
                  class="contact-social"
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon icon={icon} size="1.5em" />
                  <span>{label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .contact-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: 2.5rem;
  }

  .contact-header {
    align-items: center;
    max-width: 50ch;
  }

  .contact-title {
    font-size: var(--text-4xl);
    color: var(--gray-0);
  }

  .contact-description {
    font-size: var(--text-md);
    color: var(--gray-300);
  }

  .contact-card {
    width: 100%;
    max-width: 38rem;
    padding: 2rem;
    background: var(--gradient-subtle);
    border: 1px solid var(--gray-800);
    border-radius: 1.25rem;
    box-shadow: var(--shadow-md);
    text-align: start;
  }

  .contact-email {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    background: var(--gradient-accent-orange);
    color: var(--accent-text-over);
    border-radius: 999rem;
    text-decoration: none;
    font-weight: 600;
    font-size: var(--text-lg);
    box-shadow: var(--shadow-md);
    transition:
      transform var(--theme-transition),
      box-shadow var(--theme-transition);
  }

  .contact-email:hover,
  .contact-email:focus {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .contact-divider {
    height: 1px;
    background: var(--gray-800);
    opacity: 0.6;
    border: none;
    margin: 0.25rem 0;
  }

  .contact-socials-label {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray-300);
  }

  .contact-social-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.75rem;
  }

  .contact-social {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 1rem;
    border-radius: 999rem;
    background: var(--gray-999);
    border: 1px solid var(--gray-800);
    color: var(--gray-100);
    text-decoration: none;
    font-weight: 500;
    transition:
      color var(--theme-transition),
      border-color var(--theme-transition),
      transform var(--theme-transition);
  }

  .contact-social:hover,
  .contact-social:focus {
    color: var(--accent-regular);
    border-color: var(--accent-overlay);
    transform: translateY(-1px);
  }

  @media (min-width: 50em) {
    .contact-title {
      font-size: var(--text-5xl);
    }

    .contact-description {
      font-size: var(--text-lg);
    }
  }
</style>
