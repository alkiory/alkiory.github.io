---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTranslations, type Lang } from "../../data/i18n";
import CardPreview from "../../components/CardPreview.astro";
import Grid from "../../components/Grid.astro";
import Pill from "../../components/ui/Pill.astro";
import Hero from "../../components/ui/Hero.astro";
import Icon from "../../components/ui/icon.astro";
import { getCollection } from "astro:content";
import Skills from "../../components/Skills.astro";
import Btn from "../../components/ui/Btn.astro";
import { ROUTE_NAMES } from "../../lib/routes-names";
import { latest } from "../../lib/content-helpers";
import { Image } from "astro:assets";
import StatusBadge from "../../components/StatusBadge.astro";
import Timeline from "../../components/Timeline.astro";
import { experience } from "../../data/companies";

export async function getStaticPaths() {
  const locales = ["es", "en"];

  return locales.map((lang) => ({
    params: { lang },
  }));
}

// `Astro.currentLocale` is set by the i18n config (see
// astro.config.mjs). Fall back to the URL segment for paths that the
// Astro runtime hasn't classified yet, and finally to the default
// locale. This keeps us consistent with Nav.astro's pattern.
const lang = (Astro.currentLocale ?? Astro.url.pathname.split("/")[1]) as Lang;
const t = getTranslations(lang);

// Top 3 entries per collection; `latest()` defaults to descending
// publishDate with `id` lex as a secondary tiebreaker for same-day
// posts.
const allBlogsPost = latest(await getCollection("blog"), 3);

const allProjects = latest(await getCollection("work"), 3);
---

<BaseLayout>
  <div class="stack gap-20 lg:gap-48">
    <div class="wrapper stack gap-8 lg:gap-20">
      <header class="hero">
        <Hero title={t.home.welcome} tagline={t.home.intro} align="start">
          <div class="roles">
            <Pill><Icon icon="code" size="1.33em" /> Developer</Pill>
            <Pill><Icon icon="motorcycle" size="1.33em" /> Biker</Pill>
            <Pill><Icon icon="game-controller" size="1.33em" /> Gamer</Pill>
            <Pill><Icon icon="pencil-line" size="1.33em" /> Video</Pill>
          </div>

          <div style="margin-top: 1rem;">
            <StatusBadge />
          </div>
        </Hero>

        <Image
          data-tilt
          data-tilt-glare
          style={"object-fit: cover;"}
          alt="Rudeus"
          width={480}
          height={620}
          src="/assets/shirotaka_rudeus.jpg"
        />
      </header>

      <!-- SKILLS AND STATISTICS -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-20">
        <Skills />

        <div class="card p-8 flex flex-col justify-center" style="z-index: 10;">
          <div class="grid grid-cols-2 gap-8 text-center">
            <div>
              <div
                class="text-4xl font-bold text-[var(--accent-regular)] mb-2 font-brand"
              >
                9+
              </div>
              <p class="text-[var(--gray-400)] text-sm mt-2">
                {t.home.yearsOfExperienceDesc || "Years of Experience"}
              </p>
              <div style="margin-top: 1rem;">
                <StatusBadge />
              </div>
            </div>
            <div>
              <div
                class="text-4xl font-bold text-[var(--accent-regular)] mb-2 font-brand"
              >
                67+
              </div>
              <p class="text-[var(--gray-400)] text-sm mt-2">
                {t.home.projectsCompletedDesc || "Projects Completed"}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <main class="wrapper stack gap-20 lg:gap-48">
      <section class="section with-background with-cta">
        <header class="section-header stack gap-2 lg:gap-4">
          <h3>{t.home.selectedWorks}</h3>
          <p>
            {t.home.selectedWorksDesc}
          </p>
        </header>

        <div class="gallery">
          <Grid variant="small">
            {
              allProjects.map((project) => (
                <li>
                  <CardPreview entry={project} route={ROUTE_NAMES.WORK} />
                </li>
              ))
            }
          </Grid>
        </div>

        <div class="cta">
          <Btn href={`/${lang}${ROUTE_NAMES.WORK}/`}>
            {t.home.viewAll}
            <Icon icon="arrow-right" size="1.2em" />
          </Btn>
        </div>
      </section>

      <section class="section with-background with-cta">
        <header class="section-header stack gap-2 lg:gap-4">
          <h3>{t.home.lastBlog}</h3>
          <p>
            {t.home.lastBlogDesc}
          </p>
        </header>

        <div class="gallery">
          <Grid variant="small">
            {
              allBlogsPost.map((blog) => (
                <li>
                  <CardPreview entry={blog} route={ROUTE_NAMES.BLOG} />
                </li>
              ))
            }
          </Grid>
        </div>

        <div class="cta">
          <Btn href={`/${lang}${ROUTE_NAMES.BLOG}/`}>
            {t.home.viewAll}
            <Icon icon="arrow-right" size="1.2em" />
          </Btn>
        </div>
      </section>

      <!-- EXPERIENCE SECTION -->
      <section class="section with-background bg-variant">
        <header class="section-header stack gap-2 lg:gap-4 mb-8">
          <h3
            class="text-3xl md:text-4xl font-bold text-[var(--gray-100)] font-brand"
          >
            {t.home.workExperience}
          </h3>
          <p class="text-xl text-[var(--gray-300)]">
            {t.home.workExperienceDesc || "My professional journey"}
          </p>
        </header>

        <div class="gallery mx-auto max-w-4xl w-full">
          <Timeline items={experience} lang={lang} />
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .roles {
    display: none;
  }

  .hero img {
    aspect-ratio: 5 / 4;
    object-fit: fill;
    object-position: top;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 50em) {
    .hero {
      display: grid;
      grid-template-columns: 6fr 4fr;
      padding-inline: 2.5rem;
      gap: 3.75rem;
    }

    .roles {
      margin-top: 0.5rem;
      display: flex;
      gap: 0.5rem;
    }

    .hero img {
      aspect-ratio: 3 / 4;
      border-radius: 4.5rem;
      object-fit: cover;
    }
  }

  /* ====================================================== */

  .section {
    display: grid;
    gap: 2rem;
  }

  .with-background {
    position: relative;
  }

  .with-background::before {
    --hero-bg: var(--bg-image-subtle-2);

    content: "";
    position: absolute;
    pointer-events: none;
    left: 50%;
    width: 100vw;
    aspect-ratio: calc(2.25 / var(--bg-scale));
    top: 0;
    transform: translateY(-75%) translateX(-50%);
    background:
      url("/assets/backgrounds/noise.png") top center/220px repeat,
      var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
      var(--gray-999);
    background-blend-mode: overlay, normal, normal, normal;
    mix-blend-mode: var(--bg-blend-mode);
    z-index: -1;
  }

  .with-background.bg-variant::before {
    --hero-bg: var(--bg-image-subtle-1);
  }

  .section-header {
    justify-self: center;
    text-align: center;
    max-width: 50ch;
    font-size: var(--text-md);
    color: var(--gray-300);
  }

  .section-header h3 {
    font-size: var(--text-2xl);
  }

  @media (min-width: 50em) {
    .section {
      grid-template-columns: repeat(4, 1fr);
      grid-template-areas: "header header header header" "gallery gallery gallery gallery";
      gap: 5rem;
    }

    .section.with-cta {
      grid-template-areas: "header header header cta" "gallery gallery gallery gallery";
    }

    .section-header {
      grid-area: header;
      font-size: var(--text-lg);
    }

    .section-header h3 {
      font-size: var(--text-4xl);
    }

    .with-cta .section-header {
      justify-self: flex-start;
      text-align: left;
    }

    .gallery {
      grid-area: gallery;
    }

    .cta {
      grid-area: cta;
    }
  }

  .card {
    background: var(--gradient-subtle);
    border: 1px solid var(--gray-800);
    border-radius: 1.5rem;
    box-shadow: var(--shadow-sm);
  }
</style>
