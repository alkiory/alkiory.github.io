---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTranslations } from "../../data/i18n";
import Hero from "../../components/ui/Hero.astro";
import Grid from "../../components/Grid.astro";
import { Image } from "astro:assets";
import { techSkills, softSkills, languages, certifications } from "../../data/skills";

export async function getStaticPaths() {
  const locales = ["es", "en"];
  return locales.map((lang) => ({
    params: { lang },
  }));
}

const lang = (Astro.url.pathname.split("/")[1] as "es" | "en") || "en";
const t = getTranslations(lang as "es" | "en");
---

<BaseLayout title={t.about.title} description={t.about.description}>
  <div class="stack gap-20">
    <main class="wrapper about">
      <Hero title={t.about.title} tagline={t.about.description}>
        <Image
          style={"object-fit: cover;"}
          width={853}
          height={573}
          src="/assets/sergio_moto.webp"
          alt="Alkiory profile picture"
        />
      </Hero>

      <section>
        <h2 class="section-title">{t.about.title}</h2>
        <div class="content">
          <p class="mb-4">{t.about.introParagraph1}</p>
          <p class="mb-4">{t.about.introParagraph2}</p>
          <p class="mb-4">{t.about.introParagraph3}</p>
          <hr />
        </div>
      </section>

      <section>
        <h2 class="section-title">{t.about.techSkills}</h2>
        <div class="content">
          <Grid variant="small">
            {techSkills.map((brand) => <li class="mention-card">{brand}</li>)}
          </Grid>
          <hr />
        </div>
      </section>

      <section>
        <h2 class="section-title">{t.about.education}</h2>
        <div class="content">
          <p>Politecnico de las Costa Atlántica University.</p>
          <p class="mb-4">Sena Colombo Aleman.</p>
          <hr />
        </div>
      </section>

      <section>
        <h2 class="section-title">{t.about.softSkills}</h2>
        <div class="content">
          <Grid variant="small">
            {softSkills.map((brand) => <li class="mention-card">{brand}</li>)}
          </Grid>
          <hr />
        </div>
      </section>

      <section>
        <h2 class="section-title">{t.about.languages}</h2>
        <div class="content">
          <Grid variant="small">
            {languages.map((brand) => (
              <li class="mention-card">{brand}</li>
            ))}
          </Grid>
          <hr />
        </div>
      </section>

      <section>
        <h2 class="section-title">{t.about.certifications}</h2>
        <div class="content">
          <Grid variant="small">
            {certifications.map((brand) => (
              <li class="mention-card glow-on-hover">
                <a href={brand.web} class="brands" target="_blank" rel="noopener noreferrer">
                  {brand.name}
                </a>
              </li>
            ))}
          </Grid>
          <hr />
        </div>
      </section>

      <section>
        <div class="content">
          <p class="mb-4">{t.about.introParagraph4}</p>
          <p class="mb-4">{t.about.introParagraph5}</p>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  img {
    margin-top: 1.5rem;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--gray-200);
  }

  hr {
    border: 1px solid var(--gray-100);
    opacity: 0.2;
    margin: 1em 0;
  }

  .mb-4 {
    margin-bottom: 1rem;
  }

  .section-title {
    grid-column-start: 1;
    font-size: var(--text-xl);
    color: var(--gray-0);
  }

  .content {
    grid-column: 2 / 4;
  }

  .content :global(a) {
    text-decoration: 1px solid underline transparent;
    text-underline-offset: 0.25em;
    transition: text-decoration-color var(--theme-transition);
  }

  .content :global(a:hover),
  .content :global(a:focus) {
    text-decoration-color: currentColor;
  }

  .mention-card {
    display: flex;
    padding: 0.75rem 1rem;
    justify-content: center;
    align-items: center;
    text-align: center;
    border: 1px solid var(--accent-light);
    border-radius: 0.5rem;
    color: var(--gray-300);
    background: var(--accent-light);
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s;
    outline: none;
    position: relative;
    z-index: 0;
    font-size: var(--text-sm);
  }
  
  .mention-card:hover {
    color: var(--gray-0);
    background: var(--accent-regular);
  }
  
  .brands {
    text-decoration: none;
    color: var(--gray-300);
    transition: transform 0.2s;
  }

  @media (min-width: 50em) {
    .about {
      display: grid;
      grid-template-columns: 1fr 60% 1fr;
    }

    .about > :global(:first-child) {
      grid-column-start: 2;
    }

    section {
      display: contents;
      font-size: var(--text-lg);
    }
  }
</style>
