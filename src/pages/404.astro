---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/ui/Hero.astro";
import { getTranslations } from "../data/i18n";

// 404.astro es una ruta estática (sin [lang] dinámico), así que no usa
// getStaticPaths. Astro emite esta página como dist/404/index.html
// (con trailingSlash:'always' + build.format:'directory'). El lang
// se intenta derivar de la URL por compatibilidad con posibles refactors
// futuros que muevan 404 a src/pages/[lang]/404.astro.
const langParam = Astro.url.pathname.split("/")[1];
const lang = (langParam === "es" || langParam === "en" ? langParam : "en");
const t = getTranslations(lang);
---

<BaseLayout
  title={t?.notFound.title}
  description={t?.notFound.description}
  lang={lang}
>
  <Hero title={t?.notFound.title} tagline={t?.notFound.description} />
  <p style="text-align: center; margin-top: 2rem;">
    <a href={`/${lang}/`} class="button"> Back Home </a>
  </p>
</BaseLayout>

<style>
  .button {
    display: inline-block;
    padding: 0.8em 1.5em;
    background-color: var(--accent-regular);
    color: white;
    text-decoration: none;
    border-radius: 5px;
    transition: background-color 0.3s ease;
  }
  .button:hover {
    background-color: var(--accent-dark);
  }
</style>
