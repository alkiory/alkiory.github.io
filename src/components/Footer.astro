---
import Icon from "../components/ui/icon.astro";
import { getTranslations } from "../data/i18n";

const lang = (Astro.url.pathname.split("/")[1] as "es" | "en") || "en";
const t = getTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="site-footer flex flex-col gap-12 py-6 px-8 text-center text-sm">
  <div
    class="flex flex-col md:flex-row gap-4 md:gap-8 items-center justify-center"
  >
    <div
      class="group flex flex-col md:flex-row gap-2 md:gap-4 items-center justify-center md:justify-start"
    >
      <p class="flex items-center gap-1">
        {t?.footer.sign}
        <a
          href="https://astro.build/"
          class="footer-link"
          target="_blank"
          rel="noopener noreferrer">Astro</a
        >
        <Icon icon="rocket-launch" size="1.2em" />
      </p>
      <p class="footer-copyright">
        &copy; {currentYear}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--gray-999);
    color: var(--gray-300);
    border-top: 1px solid var(--gray-800);
    position: relative;
    overflow: hidden;
    top: 75px;
  }

  .footer-copyright {
    color: var(--gray-300);
  }

  .footer-link {
    color: var(--gray-300);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 2px;
    transition:
      color var(--theme-transition),
      text-decoration-color var(--theme-transition);
  }

  .footer-link:hover,
  .footer-link:focus {
    color: var(--gray-100);
    text-decoration-color: currentColor;
  }
</style>
