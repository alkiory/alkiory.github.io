---
import type { CollectionEntry } from "astro:content";
import { slugFromId } from "../lib/routes-names";
import { Image } from "astro:assets";
import { getTranslations, type Lang } from "../data/i18n";

interface Props {
  entry: CollectionEntry<"blog"> | CollectionEntry<"work">;
  /**
   * Route prefix for the card's href — one of ROUTE_NAMES.WORK or
   * ROUTE_NAMES.BLOG. The pattern
   * `/${lang}${route}/${slugFromId(entry.id)}` produces the canonical URL.
   */
  route: string;
}

const { entry, route } = Astro.props;
const lang = Astro.url.pathname.split("/")[1] as Lang;
const t = getTranslations(lang);
---

<a
  class="card card--entry"
  href={`/${lang}${route}/${slugFromId(entry.id)}/`}
  data-tilt
  data-tilt-glare
  data-tilt-max-glare="0.8"
>
  <span
    class="title"
    data-tooltip={t.home.viewDetails}
    title={t.home.viewDetails}
  >
    {entry.data.title}
  </span>
  <Image
    src={entry.data.img}
    alt={entry.data.img_alt || ""}
    loading="lazy"
    decoding="async"
    width={1920}
    height={1080}
  />
</a>

<style>
  .card {
    position: relative;
    display: block;
    text-decoration: none;
    font-family: var(--font-brand);
    font-weight: 500;
    transition:
      box-shadow var(--theme-transition),
      transform var(--theme-transition);
    box-shadow: var(--shadow-sm);
  }

  .card:focus-visible {
    outline: 2px solid var(--accent-regular);
    outline-offset: 4px;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .card--entry {
    height: 11rem;
    background: var(--gradient-subtle);
    border: 1px solid var(--gray-800);
    border-radius: 0.75rem;
    overflow: hidden;
    display: grid;
    grid-template: auto 1fr / auto 1fr;
    font-size: var(--text-lg);
  }

  .card--entry img {
    grid-area: 1 / 1 / 3 / 3;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card--entry .title {
    grid-area: 1 / 1 / 2 / 2;
    z-index: 4;
    margin: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--gray-999);
    color: var(--gray-200);
    border-radius: 0.375rem;
    position: relative;
    display: inline-block;
    align-self: flex-start;
    max-width: calc(100% - 1rem);
    transition:
      transform 0.18s ease-out,
      filter 0.18s ease-out;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card--entry .title::after {
    content: attr(data-tooltip);
    position: absolute;
    top: calc(100% + 0.55rem);
    left: 50%;
    transform: translate(-50%, -6px);
    padding: 0.35rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--gray-999);
    background: var(--gray-50);
    border-radius: 0.4rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    box-shadow: var(--shadow-md);
    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
    z-index: 5;
  }

  .card--entry .title::before {
    content: "";
    position: absolute;
    top: calc(100% + 0.25rem);
    left: 50%;
    transform: translate(-50%, -6px);
    width: 0;
    height: 0;
    border: 6px solid transparent;
    border-bottom-color: var(--gray-50);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
    z-index: 6;
  }

  .card--entry:hover .title,
  .card--entry:focus-visible .title {
    transform: scale(1.06) translateY(-2px);
    filter: drop-shadow(0 6px 12px var(--accent-subtle-overlay));
    will-change: transform;
  }

  .card--entry:hover .title::after,
  .card--entry:focus-visible .title::after,
  .card--entry:hover .title::before,
  .card--entry:focus-visible .title::before {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  @media (min-width: 50em) {
    .card--entry {
      height: 22rem;
      border-radius: 1.5rem;
    }

    .card--entry .title {
      border-radius: 0.9375rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .card--entry .title {
      transition: none;
    }

    .card:hover {
      transform: none;
    }

    .card--entry:hover .title,
    .card--entry:focus-visible .title {
      transform: none;
      filter: none;
      will-change: auto;
    }

    .card--entry:hover .title::after,
    .card--entry:focus-visible .title::after,
    .card--entry:hover .title::before,
    .card--entry:focus-visible .title::before {
      opacity: 0;
      transform: translate(-50%, -6px);
    }
  }
</style>
