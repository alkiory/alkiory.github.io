---
// Thin wrapper that delegates to CardPreview so the hover/tooltip
// pattern lives in one place. Portfolio/blog grids keep their explicit
// component names for readability at the call sites.
import type { CollectionEntry } from "astro:content";
import CardPreview from "./CardPreview.astro";
import { ROUTE_NAMES } from "../lib/routes-names";

interface Props {
  project: CollectionEntry<"work">;
}
const { project } = Astro.props;
---

<CardPreview entry={project} route={ROUTE_NAMES.WORK} />
