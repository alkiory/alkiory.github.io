---
import Icon from "./ui/icon.astro";
import { getLangFromUrl, getTranslations, type Lang } from "../data/i18n";

const lang: Lang =
  (Astro.currentLocale as Lang) ?? getLangFromUrl(Astro.url) ?? "en";
const t = getTranslations(lang);
---

<button
  type="button"
  class="scroll-to-top"
  aria-label={t.ui.backToTop}
  data-scroll-to-top
>
  <Icon icon="arrow-up" color="#ffffff" size="1.4em" />
</button>

<script>
  const button = document.querySelector<HTMLButtonElement>(
    "[data-scroll-to-top]",
  );

  if (button) {
    let ticking = false;
    let threshold = computeThreshold();

    // The page's CSS rules (see `src/styles/global.css`) make the
    // viewport itself the document scrollport, so `window.scrollY`
    // is authoritative.
    const getScrollTop = (): number => window.scrollY;

    const update = () => {
      const visible = getScrollTop() > threshold;
      button.classList.toggle("is-visible", visible);
      ticking = false;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    const onResize = () => {
      threshold = computeThreshold();
      update();
    };

    const initialise = () => {
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onResize, { passive: true });
      update();
    };

    if (document.documentElement.classList.contains("loaded")) {
      initialise();
    } else {
      window.addEventListener("load", initialise, { once: true });
    }

    button.addEventListener("click", () => {
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      window.scrollTo({
        top: 0,
        behavior: prefersReducedMotion ? "auto" : "smooth",
      });

      button.blur();
    });
  }

  function computeThreshold(): number {
    return Math.max(window.innerHeight * 0.5, 300);
  }
</script>

<style>
  .scroll-to-top {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 90;
    isolation: isolate;
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    padding: 0;
    margin: 0;
    border: 0;
    border-radius: 999rem;
    color: var(--gray-999);
    cursor: pointer;
    background: linear-gradient(
      135deg,
      var(--cyan-regular) 0%,
      var(--accent-regular) 100%
    );
    box-shadow: var(--shadow-md);
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition:
      opacity 0.25s ease-out,
      transform 0.25s ease-out,
      filter 0.18s ease-out;
  }

  .scroll-to-top.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .scroll-to-top::before {
    content: "";
    position: absolute;
    inset: -2px;
    z-index: -1;
    border-radius: 999rem;
    background: linear-gradient(45deg, #00ffff, #8a2be2, #00ffff, #8a2be2);
    background-size: 200%;
    opacity: 0;
    filter: blur(5px);
    animation: scroll-to-top-glow 5s linear infinite;
    transition: opacity 0.3s ease-in-out;
    pointer-events: none;
  }

  .scroll-to-top:hover::before,
  .scroll-to-top:focus-visible::before {
    opacity: 1;
  }

  @keyframes scroll-to-top-glow {
    0% {
      background-position: 0 0;
    }
    50% {
      background-position: 200% 0;
    }
    100% {
      background-position: 0 0;
    }
  }

  .scroll-to-top:hover,
  .scroll-to-top:focus-visible {
    transform: translateY(0) scale(1.06);
    filter: drop-shadow(0 6px 14px var(--accent-subtle-overlay));
  }

  .scroll-to-top:focus-visible {
    outline: 2px solid var(--accent-regular);
    outline-offset: 4px;
  }

  @media (min-width: 50em) {
    .scroll-to-top {
      right: 1.5rem;
      bottom: 1.5rem;
      width: 52px;
      height: 52px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-to-top {
      transition: opacity 0.15s linear;
      transform: none;
    }
    .scroll-to-top:hover,
    .scroll-to-top:focus-visible {
      transform: none;
    }
    .scroll-to-top::before {
      animation: none;
    }
  }
</style>
