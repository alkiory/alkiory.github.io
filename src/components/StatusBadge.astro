---
import type { Lang } from "../data/i18n";
import { getTranslations } from "../data/i18n";

const lang = (Astro.url.pathname.split("/")[1] as Lang) || "en";
const t = getTranslations(lang);
---

<div
  class="status-badge glow-on-hover inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm font-medium border border-[var(--gray-800)] bg-[var(--gray-999)] shadow-sm"
>
  <span class="status-dot"></span>
  <span class="text-[var(--gray-100)]">{t.home.statusBadge}</span>
</div>

<style>
  .status-badge {
    height: auto;
    font-family: var(--font-brand);
  }
  .status-badge::before {
    border-radius: 999px;
  }
  .status-badge::after {
    border-radius: 999px;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--accent-regular);
    position: relative;
    box-shadow: 0 0 8px var(--accent-regular);
  }

  .status-dot::after {
    content: "";
    position: absolute;
    top: -4px;
    left: -4px;
    right: -4px;
    bottom: -4px;
    border-radius: 50%;
    border: 2px solid var(--cyan-dark);
    animation: pulse 2s infinite ease-out;
    opacity: 0.8;
  }

  @keyframes pulse {
    0% {
      transform: scale(0.5);
      opacity: 0.8;
    }
    100% {
      transform: scale(2);
      opacity: 0;
    }
  }
</style>
