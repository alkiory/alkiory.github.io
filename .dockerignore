# Control de versiones
.git
.gitignore
.github
.gitattributes

# IDE / editor
.vscode
.idea
*.swp

# Dependencias y caches de build (se reconstruyen dentro de Docker)
node_modules
.npm
.pnpm-store
.astro

# Build local (se regenera en la stage builder)
dist

# Archivos de configuración sensibles / específicos del host
.env
.env.*
!.env.example
.firebase
.firebaserc
firebase.json
.firebaserc.*.json

# Logs y archivos temporales
*.log
logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Sistema operativo / misceláneos
.DS_Store
Thumbs.db
*.tgz
*.pid
*.seed
*.pid.lock

# Documentación e imágenes grandes no necesarias para el build
README.md
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.mp4
*.mov
image.png

# Dockerfiles (no necesitamos recursión)
Dockerfile.dev
docker-compose.*
.dockerignore

# Tests / cobertura
coverage
.nyc_output

# pnpm: el archivo <raíz>/pnpm-workspace.yaml es solo un README/notes
# comentado (no es config de workspace válida). pnpm 9.15.4 detecta
# el nombre y exige `packages:` -> error "packages field missing or empty".
# Sacarlo del build context evita el falso positivo en Docker; en el repo
# sigue como documentación.
pnpm-workspace.yaml

